# =============================================================================
# 안전체험관 자동화 시스템 - 환경 변수 설정 예시
# =============================================================================
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 아래 값들을 안전하게 변경
# 3. .env 파일은 Git에 커밋하지 마세요 (이미 .gitignore에 추가됨)
# =============================================================================

# =============================================================================
# 데이터베이스 설정 (필수)
# =============================================================================
# MySQL 루트 비밀번호 (강력한 비밀번호 사용 권장)
# 생성 예시: openssl rand -base64 32
DB_ROOT_PASSWORD=your-secure-root-password-here

# 애플리케이션 DB 사용자
DB_USER=safety

# 애플리케이션 DB 비밀번호 (강력한 비밀번호 사용 권장)
# 생성 예시: openssl rand -base64 32
DB_PASSWORD=your-secure-db-password-here

# =============================================================================
# JWT 설정 (필수)
# =============================================================================
# JWT 시크릿 키 (최소 256비트, 64자 이상의 랜덤 문자열 권장)
# 생성 예시: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-key-minimum-64-characters-long-random-string-here

# =============================================================================
# Flask/Face Recognition 설정 (필수)
# =============================================================================
# Flask 시크릿 키 (최소 32자 이상의 랜덤 문자열 권장)
# 생성 예시: openssl rand -hex 32
FLASK_SECRET=your-flask-secret-key-minimum-32-characters-long

# =============================================================================
# 선택적 설정 (기본값 사용 가능)
# =============================================================================
# Node 환경 (development/production)
NODE_ENV=production

# 서버 포트
BACKEND_PORT=3000
FRONTEND_PORT=5173

# CORS 설정
CORS_ORIGIN=http://localhost:5173

# 안면인식 서비스 URL
FACE_RECOGNITION_URL=http://localhost:5001

# 안면인식 모델 (hog: 빠름, cnn: 정확함)
FACE_MODEL=hog

# 안면인식 허용치 (0.0 ~ 1.0, 낮을수록 엄격)
FACE_TOLERANCE=0.6

# =============================================================================
# 보안 체크리스트
# =============================================================================
# ✅ 모든 비밀번호가 기본값이 아닌 고유한 값으로 설정되었는가?
# ✅ JWT_SECRET이 최소 64자 이상의 랜덤 문자열인가?
# ✅ FLASK_SECRET이 최소 32자 이상의 랜덤 문자열인가?
# ✅ .env 파일이 .gitignore에 포함되어 있는가?
# ✅ 프로덕션 환경에서 NODE_ENV=production으로 설정되었는가?
# =============================================================================
